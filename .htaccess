# ============================================================
# .htaccess — Apache security configuration
# ============================================================

# Disable directory listing
Options -Indexes

# Deny direct browser access to php/ folder config files
<FilesMatch "^(config|db_mysql|db_mongo|db_redis|jwt|auth)\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Protect sensitive files
<FilesMatch "\.(sql|json|md|sh|env)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Allow access to public-facing PHP endpoints only
<FilesMatch "^(register|login|logout|profile)\.php$">
    Order Deny,Allow
    Allow from all
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Redirect root to index.html
    RewriteRule ^$ index.html [L]
</IfModule>
